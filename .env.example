# --- Mapbox ---
# Public access token (pk.*). Lock it down in the Mapbox dashboard via URL restrictions.
# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_token_here

# --- Supabase (optional) ---
# Leave both blank to run in local-only mode (pins/images stored in this browser
# only). Fill both in to switch the entire app to Supabase storage automatically.
# Project Settings → API → Project URL / anon public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
